# ──────────────────────────────────────────────────────────────
# Gabi Hub — Environment Variables Template
# ──────────────────────────────────────────────────────────────
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# 📦 BANCO DE DADOS:
#     Produção usa Cloud SQL (nghost-db) no GCP.
#     Para desenvolvimento local, use Cloud SQL Proxy:
#
#     1. Instale: gcloud components install cloud-sql-proxy
#     2. Rode:    cloud-sql-proxy nghost-gabi:southamerica-east1:nghost-db --port=5433
#     3. Use a URL abaixo (já configurada para o proxy local)
#
#     ❌ NÃO use Supabase — o projeto foi migrado para GCP em Fev/2025.
# ──────────────────────────────────────────────────────────────

# Banco de dados via Cloud SQL Proxy (local, porta 5433)
GABI_DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5433/postgres

# Configuração HTTP para scrapers
TIMEOUT=30
RATE_LIMIT=2

# Habilitação de Scrapers (Agências Regulatórias)
ENABLE_SUSEP=true
ENABLE_ANS=true
ENABLE_ANPD=true
ENABLE_ANEEL=true

# Habilitação da Base de Conhecimento Jurídica (BKJ)
ENABLE_LAWS_CORE=true
ENABLE_FINANCIAL=true

# Urls customizáveis
SEED_URLS_SUSEP=https://www2.susep.gov.br/safe/bnportal/internet/pt-BR/
SEED_URLS_ANS=https://www.ans.gov.br/component/legislacao/

LOG_LEVEL=INFO
GABI_MODEL_LAW=gemini-1.5-pro
