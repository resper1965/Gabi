# Banco de dados Principal e Vetorial
GABI_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gabi

# Configuração HTTP para scrapers
TIMEOUT=30
RATE_LIMIT=2

# Habilitação de Scrapers (Agências Regulatórias)
ENABLE_SUSEP=true
ENABLE_ANS=true
ENABLE_ANPD=true
ENABLE_ANEEL=true

# Habilitação da Base de Conhecimento Jurídica (BKJ)
ENABLE_LAWS_CORE=true
ENABLE_FINANCIAL=true

# Urls customizáveis
SEED_URLS_SUSEP=https://www2.susep.gov.br/safe/bnportal/internet/pt-BR/
SEED_URLS_ANS=https://www.ans.gov.br/component/legislacao/
# Opcional: injetar lista de LAWS_SEED_URLS para a Base Jurídica via array JSON ou CSV

# (Opcional) Armazenamento em S3
# STORAGE_PATH=s3://my-bucket/regulatory
LOG_LEVEL=INFO
