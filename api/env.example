# Gabi Hub API — Environment Variables

# PostgreSQL (single brain database)
GABI_DATABASE_URL=postgresql+asyncpg://localhost:5432/gabi

# Google Cloud
GABI_GCP_PROJECT_ID=
GABI_VERTEX_AI_LOCATION=us-central1

# Model routing
GABI_MODEL_GHOST=gemini-2.0-flash-001
GABI_MODEL_LAW=gemini-1.5-pro
GABI_MODEL_NTALK=gemini-2.0-flash-001

# Embeddings (open-source, $0)
GABI_EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Firebase Auth
GABI_FIREBASE_PROJECT_ID=
GABI_FIREBASE_ADMIN_SERVICE_ACCOUNT=

# CORS (Next.js portal)
GABI_CORS_ORIGINS=["http://localhost:3000"]

# nTalkSQL
GABI_MAX_QUERY_ROWS=1000
GABI_QUERY_TIMEOUT_SECONDS=30

# DataJud CNJ — API key for STJ/STF jurisprudence ingestion.
# Key is ROTATED PERIODICALLY by CNJ — check current key at:
# https://datajud-wiki.cnj.jus.br/api-publica/
# If ingestion returns 401/403, update this value.
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendFbGFsRXFEbXFESXdmTHI6IG5HLVVjNFpHb0o0WXlMd1o1
